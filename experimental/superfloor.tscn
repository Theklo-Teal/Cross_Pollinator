[sub_resource type="GDScript" id="GDScript_ti018"]
resource_name = "superfloor"
script/source = "@tool
extends Sprite3D

const tile_size = 8

@export var size := Vector2i(12,12)
var src : Image

@export_tool_button(\"redraw\") var refl = refloor

func refloor() -> void:
	src = Image.create_empty(size.x * tile_size, size.y * tile_size, false, Image.FORMAT_RGBE9995)
	src.fill(Color.SLATE_GRAY)
	const colr := [Color.BLUE, Color.RED]
	for y in range(8):
		for x in range(8):
			var cell = Vector2i(x,y)
			print(cell)
			var rect = Rect2i(cell, Vector2i(32,32))
			src.fill_rect(rect, colr[cell.x % 2])
	texture = ImageTexture.create_from_image(src)
"

[node name="Superfloor" type="Sprite3D" unique_id=715239067]
transform = Transform3D(1, 0, 0, 0, -4.371139e-08, 1, 0, -1, -4.371139e-08, 0, 0, 0)
double_sided = false
texture = SubResource("ImageTexture_v60hi")
script = SubResource("GDScript_ti018")
