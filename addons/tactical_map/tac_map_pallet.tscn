[sub_resource type="GDScript" id="GDScript_lmyxv"]
resource_name = "Pallet_Panel"
script/source = "@tool
extends HBoxContainer

#TODO: persist which \"Other\" toggle button was pressed when the plugin quit.

signal mode_changed(mode:StringName)
signal paint_tool_changed(tool:StringName)
signal offset_map(direction:Vector2i)
signal zone_clicked()
signal zones_selected(zones:PackedStringArray)
signal zone_renamed(old_zone:String, new_zone:String)
signal zone_deleted(zone:String)
signal ladder_clicked()
signal ladders_selected(ladders:PackedStringArray)
signal ladder_renamed(old_ladder:String, new_ladder:String)
signal ladder_deleted(ladder:String)
signal nav_overlay(shown:bool)
signal floor_overlay(shown:bool)

var active_assets : Dictionary[StringName, ButtonGroup]
var paint_tool := ButtonGroup.new()
var other_mode := ButtonGroup.new()
var tool_mem : Dictionary[StringName,Button]

func _ready() -> void:
	%Picker_Spacer.custom_minimum_size.y = %Picker.size.y
	%Picker.hide()
	%Picker_Spacer.show()
	
	other_mode.allow_unpress = true
	%ZoneAdd.button_group = other_mode
	%add_spawner.button_group = other_mode
	%LadderAdd.button_group = other_mode
	%Coordi.button_group = other_mode
	
	other_mode.pressed.connect(_on_other_mode_pressed)
	
	for butt : Button in %PaintTools.get_children():
		butt.button_group = paint_tool
	
	paint_tool.pressed.connect(_on_paint_tool_pressed)
	
	%ZoneContainer.item_clicked.connect(_on_zone_clicked.unbind(2))
	%ZoneContainer.multi_selected.connect(_on_zone_multi_selected.unbind(2))
	%ZoneTitle.text_submitted.connect(_on_zone_renamed)
	%LadderContainer.item_clicked.connect(_on_ladder_clicked.unbind(2))
	%LadderContainer.multi_selected.connect(_on_ladder_multi_selected.unbind(2))
	%LadderTitle.text_submitted.connect(_on_ladder_renamed)
	
	%east.pressed.connect(func(): offset_map.emit(Vector2i.RIGHT))
	%south.pressed.connect(func(): offset_map.emit(Vector2i.DOWN))
	%west.pressed.connect(func(): offset_map.emit(Vector2i.LEFT))
	%north.pressed.connect(func(): offset_map.emit(Vector2i.UP))
	
	%Mode.tab_changed.connect(_on_mode_tab_selected)
	
	populate_thumbs.call_deferred()
	
	var unique_icon = preload(\"res://addons/tactical_map/icons/Unique_Entity.png\")
	%Spawner_Opts.clear()
	var i : int = -1
	for spawn in Tac.spawners:
		i += 1
		%Spawner_Opts.add_item(spawn)
		if not Tac.spawners[spawn].unique_to_tacnav().is_empty():
			%Spawner_Opts.set_item_icon(i, unique_icon)
	%Spawner_Opts.select( min(Tac.setts.get_value(\"ui\", \"spawner_opt\", 0), Tac.spawners.size()) )
	%Spawner_Opts.item_selected.connect(func(idx):Tac.setts.set_value(\"ui\", \"spawner_opt\", idx))
	
	%Mode.current_tab = Tac.setts.get_value(\"ui\", \"mode\", 0)
	_on_mode_tab_selected(%Mode.current_tab)
	other_mode.get_buttons()[Tac.setts.get_value(\"ui\", \"other\", 0)]

func map_changed(tacmap:TacMap):
	%ZoneContainer.clear()
	%LadderContainer.clear()
	if not tacmap == null:
		for zone in tacmap.zones:
			%ZoneContainer.add_item(zone)
		for ladder in tacmap.ladders:
			%LadderContainer.add_item(ladder)

func _on_mode_tab_selected(idx:int):
	Tac.setts.set_value(\"ui\", \"mode\", idx)
	mode_changed.emit(get_mode())
	%Terrains.current_tab = idx
	#match %Mode.get_tab_title(idx):

func _on_other_mode_pressed(button:Button):
	if %Mode.get_tab_title(%Mode.current_tab).to_lower() == \"other\":
		if button == null:
			Tac.setts.set_value(\"ui\", \"other\", -1)
		else:
			Tac.setts.set_value(\"ui\", \"other\", button.get_index())
			mode_changed.emit(get_mode())


func show_spawner_copy(rsrc:TacEntitySpawner=null):
	if rsrc == null:
		return
	%spawner_info.text = rsrc.editor_info()

func _on_show_navigation_toggled(toggled_on: bool) -> void:
	nav_overlay.emit(toggled_on)
func is_nav_overlay_visible():
	return %show_navigation.button_pressed

func _on_show_floors_toggled(toggled_on: bool) -> void:
	floor_overlay.emit(toggled_on)
func is_floor_overlay_visible():
	return %show_floors.button_pressed

#region Zoning
var last_sel_zone_idx : int = -1
var last_sel_zone : String

func select_zones(zones:PackedStringArray):
	for idx in range(%ZoneContainer.item_count):
		var zone = %ZoneContainer.get_item_text(idx)
		if zone in zones:
			%ZoneContainer.select(idx, false)
		else:
			%ZoneContainer.deselect(idx)

func _on_zone_clicked(zone_idx):
	if %ZoneContainer.is_selected(zone_idx):
		last_sel_zone_idx = zone_idx
		last_sel_zone = %ZoneContainer.get_item_text(zone_idx)
		%ZoneTitle.text = last_sel_zone
		zone_clicked.emit()

func _on_zone_multi_selected():
	var items : PackedStringArray
	for i in %ZoneContainer.get_selected_items():
		var zone = %ZoneContainer.get_item_text(i)
		items.append(zone)
	zones_selected.emit(items)

func _on_zone_renamed(text:String):
	if %ZoneContainer.is_anything_selected():
		if text.is_empty():  # Delete Zone
			%ZoneContainer.remove_item(last_sel_zone_idx)
			zone_deleted.emit(last_sel_zone)
			last_sel_zone_idx = -1
			last_sel_zone = \"\"
		elif last_sel_zone_idx >= 0:  # Rename Zone
			text = text.c_escape()
			%ZoneContainer.set_item_text(last_sel_zone_idx, text)
			zone_renamed.emit(last_sel_zone, text)
			last_sel_zone = text

func on_add_zone(existing:PackedStringArray) -> String:
	var text : String = %ZoneTitle.text
	text = text.c_escape()
	if text.is_empty():
		return \"\"
	if text in existing: # If there's a zone that was expected to be on the list, but isn't, we add it, then select it.
		var idx : int = -1
		for i in range(%ZoneContainer.item_count):
			if %ZoneContainer.get_item_text(i) == text:
				idx = i
				break
		if idx < 0:
			idx = %ZoneContainer.add_item(text)
		%ZoneContainer.select(idx)
	else:  # It's a new zone.
		var idx = %ZoneContainer.add_item(text)
		%ZoneContainer.select(idx)
	return text

#endregion

#region Ladders
var last_sel_ladder_idx : int = -1
var last_sel_ladder : String

func select_ladders(ladders:PackedStringArray):
	for idx in range(%LadderContainer.item_count):
		var ladder = %LadderContainer.get_item_text(idx)
		if ladder in ladders:
			%LadderContainer.select(idx, false)
		else:
			%LadderContainer.deselect(idx)

func _on_ladder_clicked(ladder_idx):
	if %LadderContainer.is_selected(ladder_idx):
		last_sel_ladder_idx = ladder_idx
		last_sel_ladder = %LadderContainer.get_item_text(ladder_idx)
		%LadderTitle.text = last_sel_ladder
		ladder_clicked.emit()

func _on_ladder_multi_selected():
	var items : PackedStringArray
	for i in %LadderContainer.get_selected_items():
		var ladder = %LadderContainer.get_item_text(i)
		items.append(ladder)
	ladders_selected.emit(items)

func _on_ladder_renamed(text:String):
	if %LadderContainer.is_anything_selected():
		if text.is_empty():  # Delete Ladder
			%LadderContainer.remove_item(last_sel_ladder_idx)
			ladder_deleted.emit(last_sel_ladder)
			last_sel_ladder_idx = -1
			last_sel_ladder = \"\"
		elif last_sel_ladder_idx >= 0:  # Rename Ladder
			text = text.c_escape()
			%LadderContainer.set_item_text(last_sel_ladder_idx, text)
			ladder_renamed.emit(last_sel_ladder, text)
			last_sel_ladder = text

func on_add_ladder(existing:PackedStringArray) -> String:
	var text : String = %LadderTitle.text
	text = text.c_escape()
	if text.is_empty():
		return \"\"
	if text in existing: # If there's a ladder that was expected to be on the list, but isn't, we add it, then select it.
		var idx : int = -1
		for i in range(%LadderContainer.item_count):
			if %LadderContainer.get_item_text(i) == text:
				idx = i
				break
		if idx < 0:
			idx = %LadderContainer.add_item(text)
		%LadderContainer.select(idx)
	else:  # It's a new ladder.
		var idx = %LadderContainer.add_item(text)
		%LadderContainer.select(idx)
	return text
#endregion

#region Painting
func set_active_asset(info_uid:StringName):
	if not Tac.pallet_info.has(info_uid):
		return
	var info = Tac.pallet_info[info_uid]
	var terr_fam : StringName = info.get_meta(\"terrain_family\", \"\")
	for i in range(%Mode.tab_count):
		if %Mode.get_tab_title(i).to_lower() == terr_fam:
			%Mode.current_tab = i
			_on_mode_tab_selected(i)
			break
	for each : Button in active_assets[terr_fam].get_buttons():
		if each.get_meta(\"asset_info_uid\") == info_uid:
			each.button_pressed = true
			break

func get_active_asset_info_uid() -> StringName:
	var active_asset_button = active_assets[get_mode()].get_pressed_button()
	var uid : String = active_asset_button.get_meta(\"asset_info_uid\", \"\")
	return uid

func get_mode() -> StringName:
	var tab = %Mode.get_tab_title(Tac.setts.get_value(\"ui\", \"mode\", 0)).to_lower()
	match tab:
		\"other\":
			var other = other_mode.get_pressed_button()
			if other == null:
				other = \"\"
			else:
				other = other.name
			match other:
				\"add_spawner\":
					return &\"spawner\"
				\"ZoneAdd\":
					return &\"zoning\"
				\"LadderAdd\":
					return &\"ladders\"
				\"Coordi\":
					return &\"coordcapt\"
				_:
					return \"\"
		var mode:
			return mode

func get_spawner() -> StringName:
	return %Spawner_Opts.get_item_text(%Spawner_Opts.selected)

func get_paint_tool() -> String:
	return paint_tool.get_pressed_button().name

func force_paint_tool(...tools):
	var select = tool_mem.get(get_mode(), null)
	var first = null
	for each in paint_tool.get_buttons():
		if each.name in tools:
			each.disabled = false
			if first == null:
				first = each
			if select == each:
				each.button_pressed = true
		else:
			each.disabled = true
	if select == null and first != null:
		first.button_pressed = true

func _on_paint_tool_pressed(butt:Button):
	tool_mem[get_mode()] = butt
	paint_tool_changed.emit(butt.name)

func set_help(text:String):
	%Help.text = text

func set_tile_info(nav_coord:Vector2i, map_coord:Vector2i, obstacle_code:Dictionary, tile:TacTile):
	%Coordi_Text.text = str([map_coord, nav_coord][int(%nav_tile.button_pressed)])
	if obstacle_code.is_empty():
		%Obstacles.text = str(-255)
		%Obstacles.tooltip_text = \"Transitions: Invalid Navigation!\"
	else:
		%Obstacles.text = String.num_uint64(obstacle_code.code, 2).lpad(8, \"0\")
		%Obstacles.tooltip_text = \"Transitions:\\nEast:\\t\"+str(obstacle_code.sides[0])+\"\\nSouth:\\t\"+str(obstacle_code.sides[1])+\"\\nWest:\\t\"+str(obstacle_code.sides[2])+\"\\nNorth:\\t\"+str(obstacle_code.sides[3])
#endregion

func populate_thumbs():
	for terr_fam in Tac.pallet_fam:
		active_assets[terr_fam] = ButtonGroup.new()
		var thumb_container = %Terrains.get_node(terr_fam + \"/ScrollContainer2/Thumbnails\")
		var tag_container = %Terrains.get_node(terr_fam + \"/TagContainer/ScrollContainer/Tags\")
		var past_first := false
		for info_uid in Tac.pallet_fam[terr_fam]:
			var thumb : Texture
			var title : String
			match terr_fam:
				\"floor\":
					var info : FloorInfo = Tac.pallet_info[info_uid]
					thumb = info.atlas
					title = info.name
				\"tall\", \"half\", \"crawl\":
					var info : WallInfo = Tac.pallet_info[info_uid]
					thumb = info.thumbnail
					title = info.name
			
			var button := Button.new()
			button.text = title
			button.icon = thumb
			button.set_meta(\"asset_info_uid\", info_uid)
			button.icon_alignment = HORIZONTAL_ALIGNMENT_CENTER
			button.vertical_icon_alignment = VERTICAL_ALIGNMENT_TOP
			button.toggle_mode = true
			button.button_group = active_assets[terr_fam]
			thumb_container.add_child(button)
			if not past_first:
				past_first = true
				button.set_pressed_no_signal(true)
"

