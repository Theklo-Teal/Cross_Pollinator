[sub_resource type="GDScript" id="GDScript_yp348"]
script/source = "extends Character

#NOTE We have to check «is_busy» for the character performing _interaction, so it doens't try to have other actions in the middle of it.

var voice = {
	\"on_the_way\" : preload(\"res://assets/voices/confirmation_5_karen.wav\"),
	\"greeting\" : preload(\"res://assets/voices/greeting_10_karen.wav\"),
	\"complete\" : preload(\"res://assets/voices/completion_8_karen.wav\"),
	\"ready\" : preload(\"res://assets/voices/completion_4_karen.wav\"),
	}

func _interaction():
	if not is_busy:
		is_busy = true
		$voice.stream = voice.greeting
		$voice.play()
		$body_model/AnimationPlayer.play(\"pose_T\")
		await $body_model/AnimationPlayer.animation_finished
		await get_tree().create_timer(0.5).timeout
		$body_model/AnimationPlayer.play(\"act_idle\")
		is_busy = false

func idle_enter():
	$body_model/AnimationPlayer.play(\"act_idle\")

func walk_started():
	$body_model/AnimationPlayer.play(\"act_walk_PHY\")
	$voice.stream = voice.on_the_way
	$voice.play()

func walk_finished():
	$voice.stream = voice.ready
	$voice.play()
"

