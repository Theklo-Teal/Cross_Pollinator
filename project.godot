; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="XPoll"
run/main_scene="uid://8xdvbddoca3k"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="uid://b001fw7qgf0b6"

[audio]

buses/default_bus_layout="uid://btmvbgenbldbo"

[autoload]

Con="*uid://sbrt0ltctq2"
Ses="*uid://c4v00bpdocm1n"
Tac="*uid://dglwlgu3v753o"

[debug]

gdscript/warnings/unused_parameter=0

[editor]

movie_writer/ogv/encoding_speed=2
movie_writer/movie_file="/mnt/Expanse/Godot/Projects/Cross_Pollinator/media/Demo.ogv"
movie_writer/fps=30

[editor_plugins]

enabled=PackedStringArray("res://addons/plugin_reload/plugin.cfg", "res://addons/tactical_map/plugin.cfg")

[file_customization]

folder_colors={
"res://addons/": "purple",
"res://characters/": "teal",
"res://equipment/": "green",
"res://globals/": "gray",
"res://interface/": "red",
"res://modules/": "purple",
"res://quests/": "orange",
"res://scenarios/": "yellow"
}

[global_group]

Scenario_UI="A control node that can change visibility at request of ScenarioStates."

