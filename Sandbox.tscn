[sub_resource type="GDScript" id="GDScript_vrv26"]
script/source = "extends TacInterface

func _ready() -> void:
	$TacNav.zone_entered.connect(func(entity, zone): print(\"Sandbox: \", entity, \" has entered \", zone))

func _input(event: InputEvent) -> void:
	super(event)
	if event is InputEventMouseMotion:
		if Tac.hover_map == null:
			return
		$Label3D.position = Tac.hover_nav.tile2spatial(Tac.hover_tile, Tac.hover_layer, true)
		$Label3D.position.y += 0.5
		$Label3D.text = Tac.hover_map.name + \"\\n\"
		$Label3D.text += \"Nav:\" + str(Tac.hover_tile_nav) + \"\\n\"
		$Label3D.text += \"Map:\" + str(Tac.hover_tile_map)
"

