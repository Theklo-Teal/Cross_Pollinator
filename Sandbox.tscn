[ext_resource type="Script" uid="uid://darbq45b7j8m" path="res://addons/tactical_map/resource_classes/tac_tile.gd" id="3_jgjqi"]
[ext_resource type="Script" uid="uid://b624fpjrvtg43" path="res://addons/tactical_map/node_classes/tac_nav_node.gd" id="4_u6t3p"]
[ext_resource type="Script" uid="uid://h31ri5gda1bq" path="res://addons/tactical_map/node_classes/tac_map_node.gd" id="5_fucb2"]

[sub_resource type="GDScript" id="GDScript_vrv26"]
script/source = "extends ScenarioDirector

func _input(event: InputEvent) -> void:
	super(event)
	if event is InputEventMouseMotion:
		if Ses.hover_map == null:
			return
		$Label3D.position = Saliko.Vec2AddAxis(Ses.hover_tile, 1, 0.5) 
		$Label3D.position += Vector3(0.5,0,0.5) * $TacNav.tile_size
		var conn = $TacNav.get_connections(Ses.hover_tile, Ses.hover_map.get_nav_layer())
		$Label3D.text = str(Ses.hover_tile.x) + \",\" + str(Ses.hover_tile.y)
		$Label3D.text += \"\\n\" + String.num_uint64(conn[Tac.Trans.PASS], 2).lpad(4, \"0\")
		var tacnav :TacNav = Ses.hover_map.get_parent()
		var is_valid = Ses.hover_map.tiles.has(tacnav.nav2map(Ses.hover_tile, Ses.hover_map))
		$Label3D.text += \"\\n\" + [\"empty\", \"valid\"][int(is_valid)]
		
"

